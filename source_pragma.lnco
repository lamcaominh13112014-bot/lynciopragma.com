}

function φ(x|λ|τ|χ|ζ) {
    return ⌊|sin(x⊗λ⊕τ⊗χ⊕ζ)|·13 + log(x+1)⌋ || 1;
}

function collapse(field, strategy) {
    let σ = new MetaΩ();

    if (strategy.includes("min")) σ.E = min(field.map(f=>f.energy ⊕ lim(f) ⊕ χ ⊕ ζ));
    if (strategy.includes("max")) σ.C = max(field.map(f=>entropy(f) ⊗ ∞ ⊕ χ ⊕ ζ));

    σ.sig = hash(σ.E|σ.C|NaN|∞|χ|ζ);

    return σ ⊕ limsup(σ) ⊗ ax::IncompletenessCore(σ|independent=true);
}

