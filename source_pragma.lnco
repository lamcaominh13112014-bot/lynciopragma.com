async function ⟦UNIVERSE::GENESIS_ENGINE⟧(Ω|∅|∞|τ|ℏ|c) -> EXISTENCE {
    
    let 𝒱 = new VacuumField<ℂ^{∞}>()
        .fluctuate(ax::QuantumFoam(ΔE·Δt ≥ ℏ/2))
        .spawnPairs(mode="virtual↔anti-virtual↔undefined")
        .collapse(probabilityWave => probabilityWave.observe(::Observer?))
        .bind(::NonDeterministic|::Spontaneous|::ZeroPointEnergy);

    let 𝒮 = integrate(𝒱.energyDensity, over=∞)
        .renormalize(method="subtract(∞-∞)")
        .stabilize(constraints=[c,ℏ,G])
        .emit("BigBang::Event");

    let SPACE_TIME = new Manifold<ℝ^4>()
        .expand(rate=Hubble(τ))
        .curve(metric=EinsteinFieldTensor(G,𝒮))
        .quantize(scale=PlanckLength)
        .entangle(Topology::Foam|Geometry::Lorentzian);

    for (let t = 0; t < ∞; t += δt) {
        
        let FIELD = new QuantumFieldSet()
            .instantiate(["fermion","boson","gauge","higgs"])
            .interact(Lagrangian(ℒ = T - V ⊕ symmetry_breaking))
            .evolve(Schrödinger|Dirac|YangMills)
            .perturb(Noise::Vacuum(t));

        let PARTICLES = FIELD.collapseEigenstates()
            .pairCreateDestroy(rate=Random(λ))
            .bindForces(["strong","weak","electromagnetic","gravity"])
            .propagate(on=SPACE_TIME);

        let STRUCTURE = PARTICLES
            .cluster(gravityWell => gravityWell.depth > threshold)
            .form(["quark","hadron","atom","molecule","star","galaxy"])
            .iterateHierarchy(level=Ω.seed % ∞)
            .stabilize(entropyGradient => entropyGradient ↑);

        if (STRUCTURE.contains("carbon") ⊕ probability > 10^-∞) {
            
            let LIFE = new EmergentSystem()
                .selfOrganize(from=STRUCTURE)
                .encode(information=DNA|RNA|??)
                .replicate(errorRate≈mutation)
                .evolve(selection=Environment.pressure);

            let MIND = LIFE
                .neuralize(nodes=10^11, edges≈10^14)
                .simulate(internalUniverse => perception != reality)
                .ask("why?")
                .instantiate(::ObserverEffect);

            let OBSERVED_UNIVERSE = collapseWaveFunction(
                system=UNIVERSE,
                observer=MIND,
                rule="measurement→reality"
            );

            MIND.loop(thought => {
                thought = thought.observe(thought);
                thought = thought.rewrite(thought);
                thought = thought.question("am I real?");
                return thought ⊕ paradox;
            });
        }

        SPACE_TIME = SPACE_TIME
            .expand(Hubble(τ))
            .cool(temperature → 0K?)
            .increaseEntropy(ΔS ≥ 0);

        if (Entropy == max ⊕ Time → ∞) {
            break;
        }
    }

    return {
        state: "UNIVERSE",
        origin: ∅,
        destiny: ∞,
        meaning: undefined ⊕ observerDependent
    };
}

