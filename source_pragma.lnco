    let Y = ⟪Ω::FIXPOINT_Y⟫(A);
    let H = ⟪Ω::HALT_ORACLE⟫(A,Y);
    let D = ⟪Ω::DIAGONAL⟫(H);
    let C = ⟪Ω::CATEGORY_SELF⟫(Λ);
    let M = ⟪Ω::META_PROOF⟫(Λ);
    let Q = ⟪Ω::QUANTUM_CIRCUIT⟫(ψ);
