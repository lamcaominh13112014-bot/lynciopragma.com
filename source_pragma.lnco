            .instantiate(["fermion","boson","gauge","higgs","ghost","virtual","undefined"])
            .interact(Lagrangian(ℒ = T - V ⊕ symmetry_break ⊕ paradox ⊕ ∞))
            .evolve(Schrödinger ⊕ Dirac ⊕ YangMills ⊕ NavierStokes? ⊕ unknown)
