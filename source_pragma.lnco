        .map(s=>s.render(::GPU::∞|::Ray::March|::Temporal::⊕|::AxiomBlend|::VoidPass))
        .reduce((a,b)=>a.merge(b,mode="xor⊕add⊖void⊕axiom⊕Ω"));

